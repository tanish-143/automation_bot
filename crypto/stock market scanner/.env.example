# ═══════════════════════════════════════════════════════════════════════
# Market Scanner — Environment Variables
# Copy to .env and fill in real values.  Prefix: SCANNER_
# ═══════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────
SCANNER_ENV=development            # development | staging | production

# ── Database (TimescaleDB / PostgreSQL) ──────────────────────────────
SCANNER_DATABASE_URL=postgresql+asyncpg://scanner:scanner@db:5432/scanner
SCANNER_DATABASE_URL_SYNC=postgresql://scanner:scanner@db:5432/scanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=scanner
POSTGRES_DB=scanner

# ── Redis (Celery broker + result backend + cache) ───────────────────
SCANNER_REDIS_URL=redis://redis:6379/0

# ── CoinGecko REST API (free, no key required) ──────────────────────
SCANNER_COINGECKO_REST_BASE=https://api.coingecko.com/api/v3
SCANNER_COINGECKO_RATE_LIMIT_PER_MIN=30

# ── CoinCap WebSocket (free, no key required) ───────────────────────
SCANNER_COINCAP_WS_URL=wss://ws.coincap.io/prices?assets=ALL

# ── Scanner Tuning ───────────────────────────────────────────────────
SCANNER_SCAN_INTERVAL_SECONDS=60
SCANNER_SNAPSHOT_TICK_SECONDS=10
SCANNER_MIN_VOLUME_FLOOR_USD=10000
SCANNER_STALE_DATA_SECONDS=120

# ── Alerting — Slack ─────────────────────────────────────────────────
SCANNER_SLACK_WEBHOOK_URL=

# ── Alerting — Telegram ──────────────────────────────────────────────
SCANNER_TELEGRAM_BOT_TOKEN=
SCANNER_TELEGRAM_DEFAULT_CHAT_ID=

# ── Alerting — Email (SMTP / SendGrid) ───────────────────────────────
SCANNER_SMTP_HOST=
SCANNER_SMTP_PORT=587
SCANNER_SMTP_USER=
SCANNER_SMTP_PASSWORD=
SCANNER_SMTP_FROM=scanner@example.com

# ── API Server ───────────────────────────────────────────────────────
SCANNER_API_HOST=0.0.0.0
SCANNER_API_PORT=8000
SCANNER_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Frontend (Vite build-time) ───────────────────────────────────────
VITE_API_BASE=
VITE_WS_URL=
